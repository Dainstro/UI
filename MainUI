    Background   = Color3.fromRGB(18, 18, 22),
    Surface      = Color3.fromRGB(26, 26, 32),
    SurfaceAlt   = Color3.fromRGB(32, 32, 40),
    Border       = Color3.fromRGB(255, 255, 255),
    Accent       = Color3.fromRGB(120, 80, 255),
    AccentGlow   = Color3.fromRGB(160, 120, 255),
    AccentDim    = Color3.fromRGB(70, 45, 160),
    TextPrimary  = Color3.fromRGB(235, 235, 245),
    TextSecond   = Color3.fromRGB(155, 155, 175),
    TextMuted    = Color3.fromRGB(90, 90, 110),
    Success      = Color3.fromRGB(80, 220, 140),
    Danger       = Color3.fromRGB(255, 80, 100),
    SliderTrack  = Color3.fromRGB(40, 40, 52),
}

local TWEEN_FAST   = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_MED    = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_SLOW   = TweenInfo.new(0.4,  Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local TWEEN_SPRING = TweenInfo.new(0.5,  Enum.EasingStyle.Back,  Enum.EasingDirection.Out)

-- ─── Utility Functions ───────────────────────────────────────────────────────
local function Tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function MakeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 12)
    c.Parent = parent
    return c
end

local function MakeStroke(parent, transparency, color, thickness)
    local s = Instance.new("UIStroke")
    s.Transparency = transparency or 0.4
    s.Color = color or COLORS.Border
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function MakePadding(parent, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 6)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left   or 6)
    p.PaddingRight  = UDim.new(0, right  or 6)
    p.Parent = parent
    return p
end

local function MakeLabel(parent, text, size, color, weight)
    local l = Instance.new("TextLabel")
    l.Text = text or ""
    l.TextSize = size or 14
    l.TextColor3 = color or COLORS.TextPrimary
    l.Font = weight or Enum.Font.GothamMedium
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.Parent = parent
    return l
end

local function MakeFrame(parent, size, pos, color, transparency)
    local f = Instance.new("Frame")
    f.Size = size or UDim2.new(1, 0, 1, 0)
    f.Position = pos or UDim2.new(0, 0, 0, 0)
    f.BackgroundColor3 = color or COLORS.Surface
    f.BackgroundTransparency = transparency or 0
    f.BorderSizePixel = 0
    f.Parent = parent
    return f
end

local function Clamp(v, mn, mx) return math.max(mn, math.min(mx, v)) end

local function HSVtoRGB(h, s, v)
    return Color3.fromHSV(h, s, v)
end

-- ─── Tooltip System ──────────────────────────────────────────────────────────
local TooltipFrame = nil
local TooltipLabel = nil
local TooltipConn  = nil

local function InitTooltip(screenGui)
    TooltipFrame = Instance.new("Frame")
    TooltipFrame.Name = "VKTooltip"
    TooltipFrame.Size = UDim2.new(0, 180, 0, 32)
    TooltipFrame.BackgroundColor3 = COLORS.SurfaceAlt
    TooltipFrame.BackgroundTransparency = 0.2
    TooltipFrame.BorderSizePixel = 0
    TooltipFrame.ZIndex = 9999
    TooltipFrame.Visible = false
    TooltipFrame.Parent = screenGui
    MakeCorner(TooltipFrame, 8)
    MakeStroke(TooltipFrame, 0.7)
    MakePadding(TooltipFrame, 0, 0, 10, 10)

    TooltipLabel = MakeLabel(TooltipFrame, "", 12, COLORS.TextSecond)
    TooltipLabel.Size = UDim2.new(1, 0, 1, 0)
    TooltipLabel.ZIndex = 9999
end

local function ShowTooltip(text)
    if not TooltipFrame then return end
    TooltipLabel.Text = text
    TooltipFrame.Visible = true
    TooltipFrame.BackgroundTransparency = 1
    TooltipLabel.TextTransparency = 1
    Tween(TooltipFrame, TWEEN_FAST, { BackgroundTransparency = 0.2 })
    Tween(TooltipLabel, TWEEN_FAST, { TextTransparency = 0 })
    if TooltipConn then TooltipConn:Disconnect() end
    TooltipConn = RunService.RenderStepped:Connect(function()
        if not TooltipFrame.Visible then return end
        local mp = UserInputService:GetMouseLocation()
        local objects = SCREENGUI:GetGuiObjectsAtPosition(mp.X, mp.Y)
        TooltipFrame.Position = UDim2.new(0, mp.X + 14, 0, mp.Y - 40)
        -- Ensure it's above the topmost element
        if #objects > 0 then
            local topZ = 0
            for _, obj in ipairs(objects) do
                if obj.ZIndex and obj.ZIndex > topZ then
                    topZ = obj.ZIndex
                end
            end
            TooltipFrame.ZIndex = topZ + 1
            TooltipLabel.ZIndex = topZ + 2
        end
    end)
end

local function HideTooltip()
    if not TooltipFrame then return end
    Tween(TooltipFrame, TWEEN_FAST, { BackgroundTransparency = 1 })
    local t = Tween(TooltipLabel, TWEEN_FAST, { TextTransparency = 1 })
    t.Completed:Connect(function()
        TooltipFrame.Visible = false
        if TooltipConn then
            TooltipConn:Disconnect()
            TooltipConn = nil
        end
    end)
end

local function AddTooltip(element, text)
    element.MouseEnter:Connect(function() ShowTooltip(text) end)
    element.MouseLeave:Connect(function() HideTooltip() end)
end

