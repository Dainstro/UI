        -- в”Ђв”Ђ AddToggle в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        function Tab:AddToggle(name, default, cb, tip)
            local state = default == true
            local c     = card(44)

            local lbl = label(c, name, 13, C.TxtPri, Enum.Font.GothamMedium)
            lbl.Size = UDim2.new(1,-60,1,0)

            -- Track
            local track = frame(c, UDim2.new(0,42,0,22), UDim2.new(1,-44,0.5,-11),
                state and C.Accent or C.ToggleOff, 0)
            corner(track, 11)
            stroke(track, state and 0.7 or 0.6, state and C.AccentLight or C.RimOuter, 1)

            -- Nub with inner glow
            local nub = frame(track, UDim2.new(0,16,0,16),
                UDim2.new(0, state and 22 or 2, 0.5,-8), C.TxtPri, 0)
            corner(nub, 8)
            -- nub glow dot
            local nubDot = frame(nub, UDim2.new(0,6,0,6), UDim2.new(0.5,-3,0.5,-3),
                state and C.Accent or C.TxtDim, state and 0 or 0.6)
            corner(nubDot, 3)

            local hitBtn = Instance.new("TextButton")
            hitBtn.Size                  = UDim2.new(1,0,1,0)
            hitBtn.BackgroundTransparency= 1
            hitBtn.Text                  = ""
            hitBtn.Parent                = c

            local function setToggle(s)
                state = s
                tw(track,  TI.med, { BackgroundColor3  = s and C.Accent or C.ToggleOff })
                tw(nub,    TI.med, { Position = UDim2.new(0, s and 22 or 2, 0.5,-8) })
                tw(nubDot, TI.med, {
                    BackgroundColor3     = s and C.Accent or C.TxtDim,
                    BackgroundTransparency = s and 0 or 0.6
                })
                local ts = track:FindFirstChildWhichIsA("UIStroke")
                if ts then tw(ts, TI.fast, {
                    Transparency = s and 0.55 or 0.70,
                    Color        = s and C.AccentLight or C.RimOuter
                }) end
                if cb then task.spawn(pcall, cb, state) end
            end

            hitBtn.MouseButton1Click:Connect(function() setToggle(not state) end)
            if tip then addTip(hitBtn, tip) end

            return {
                Set = function(_,v) setToggle(v) end,
                Get = function() return state end,
            }
        end

        -- в”Ђв”Ђ AddSlider в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        function Tab:AddSlider(name, mn, mx, def, cb, tip)
            mn, mx, def = mn or 0, mx or 100, clamp(def or mn or 0, mn or 0, mx or 100)
            local value = def
            local c     = card(60)

            -- Label row
            local rowTop = frame(c, UDim2.new(1,0,0,18), UDim2.new(0,0,0,0), C.Win, 1)
            local nameLbl = label(rowTop, name, 12, C.TxtPri, Enum.Font.GothamMedium)
            nameLbl.Size = UDim2.new(1,-50,1,0)

            local valFrame = frame(rowTop, UDim2.new(0,44,0,18), UDim2.new(1,-44,0,0), C.AccentDark, 0.30)
            corner(valFrame, 5)
            local valLbl = label(valFrame, tostring(value), 11, C.TxtAccent, Enum.Font.GothamBold)
            valLbl.Size = UDim2.new(1,0,1,0)
            valLbl.TextXAlignment = Enum.TextXAlignment.Center

            -- Track bg
            local trackBg = frame(c, UDim2.new(1,0,0,8), UDim2.new(0,0,0,26), C.TrackBg, 0)
            corner(trackBg, 4)
            stroke(trackBg, 0.80, C.RimOuter, 1)

            -- Fill
            local pct  = (value - mn) / (mx - mn)
            local fill = frame(trackBg, UDim2.new(pct,0,1,0), nil, C.Accent, 0)
            corner(fill, 4)
            -- Gradient on fill
            local fillGrad = Instance.new("UIGradient")
            fillGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, C.AccentDark),
                ColorSequenceKeypoint.new(1, C.AccentLight),
            })
            fillGrad.Parent = fill

            -- Thumb
            local thumb = frame(trackBg, UDim2.new(0,14,0,14), UDim2.new(pct,-7,0.5,-7), C.TxtPri, 0)
            corner(thumb, 7)
            stroke(thumb, 0.3, C.Accent, 2)

            local dragging = false
            local function update(x)
                local ap = trackBg.AbsolutePosition.X
                local as = trackBg.AbsoluteSize.X
                local r  = clamp((x - ap)/as, 0, 1)
                value = math.floor(mn + r*(mx-mn) + 0.5)
                local np = (value-mn)/(mx-mn)
                tw(fill,  TI.snap, { Size     = UDim2.new(np,0,1,0) })
                tw(thumb, TI.snap, { Position = UDim2.new(np,-7,0.5,-7) })
                valLbl.Text = tostring(value)
                if cb then task.spawn(pcall, cb, value) end
            end

            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true; update(i.Position.X)
                end
            end)
            thumb.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    tw(thumb, TI.snap, { Size = UDim2.new(0,18,0,18), Position = UDim2.new(pct,-9,0.5,-9) })
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                    update(i.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
                    dragging = false
                    tw(thumb, TI.fast, { Size = UDim2.new(0,14,0,14) })
                end
            end)
            if tip then addTip(trackBg, tip) end

            return {
                Get = function() return value end,
                Set = function(_, v)
                    v = clamp(v, mn, mx)
                    update(trackBg.AbsolutePosition.X + (v-mn)/(mx-mn)*trackBg.AbsoluteSize.X)
                end,
            }
        end

        -- в”Ђв”Ђ AddDropdown в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
