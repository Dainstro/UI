function VoidKnightUI.Notify(title, content, duration)
    if not NotifyContainer then return end
    duration = duration or 4

    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 70)
    card.BackgroundColor3 = COLORS.Surface
    card.BackgroundTransparency = 0.15
    card.BorderSizePixel = 0
    card.Position = UDim2.new(1.2, 0, 0, 0)
    card.ZIndex = 8001
    card.Parent = NotifyContainer
    MakeCorner(card, 12)
    MakeStroke(card, 0.75)

    -- Accent left bar
    local bar = MakeFrame(card, UDim2.new(0, 3, 0.7, 0), UDim2.new(0, 8, 0.15, 0), COLORS.Accent, 0)
    MakeCorner(bar, 2)

    local inner = MakeFrame(card, UDim2.new(1, -24, 1, 0), UDim2.new(0, 20, 0, 0), COLORS.Background, 1)

    local titleL = MakeLabel(inner, title, 13, COLORS.TextPrimary, Enum.Font.GothamBold)
    titleL.Size = UDim2.new(1, 0, 0, 22)
    titleL.Position = UDim2.new(0, 0, 0, 10)
    titleL.ZIndex = 8002

    local contentL = MakeLabel(inner, content, 12, COLORS.TextSecond)
    contentL.Size = UDim2.new(1, 0, 0, 18)
    contentL.Position = UDim2.new(0, 0, 0, 32)
    contentL.ZIndex = 8002
    contentL.TextTruncate = Enum.TextTruncate.AtEnd

    -- Progress bar
    local progress = MakeFrame(card, UDim2.new(1, 0, 0, 2), UDim2.new(0, 0, 1, -2), COLORS.Accent, 0)
    MakeCorner(progress, 2)

    -- Slide in
    Tween(card, TWEEN_SPRING, { Position = UDim2.new(0, 0, 0, 0) })
    Tween(progress, TweenInfo.new(duration, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 0, 2) })

    task.delay(duration, function()
        Tween(card, TWEEN_MED, { Position = UDim2.new(1.2, 0, 0, 0) })
        task.wait(0.3)
        card:Destroy()
    end)
end

