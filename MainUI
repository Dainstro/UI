        -- в”Ђв”Ђ AddColorPicker в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        function Tab:AddColorPicker(name, default, cb, tip)
            local col  = default or Color3.fromRGB(99, 102, 241)
            local h, s, v = col:ToHSV()
            local open = false

            local c = card(44)
            c.ClipsDescendants = false

            local nameLbl = label(c, name, 13, C.TxtPri, Enum.Font.GothamMedium)
            nameLbl.Size = UDim2.new(1,-56,1,0)

            local preview = frame(c, UDim2.new(0,40,0,26), UDim2.new(1,-44,0.5,-13), col, 0)
            corner(preview, 7)
            stroke(preview, 0.65, C.RimInner, 1)
            -- Checkerboard pattern hint
            local cbLabel = label(preview, "в—Џ", 11, C.TxtPri)
            cbLabel.Size = UDim2.new(1,0,1,0); cbLabel.TextXAlignment = Enum.TextXAlignment.Center
            cbLabel.TextTransparency = 0.7

            -- Sub-panel
            local SUB_H = 138
            local sub   = frame(c, UDim2.new(1,0,0,0), UDim2.new(0,0,1,5), C.PanelAlt, 0.08)
            sub.ZIndex           = 150
            sub.ClipsDescendants = true
            corner(sub, 10)
            stroke(sub, 0.75, C.RimInner, 1)
            pad(sub, 10,10,12,12)

            local subInner = frame(sub, UDim2.new(1,0,0,118), UDim2.new(0,0,0,0), C.Win, 1)
            subInner.ZIndex = 151

            -- Channel row builder
            local channels = {}
            local function chanRow(lname, initV, accentCol, rowY)
                local row  = frame(subInner, UDim2.new(1,0,0,28), UDim2.new(0,0,0,rowY), C.Win, 1)
                row.ZIndex = 151
                local lbl2 = label(row, lname, 10, C.TxtDim, Enum.Font.GothamBold)
                lbl2.Size    = UDim2.new(0,12,1,0)
                lbl2.ZIndex  = 152

                local bg = frame(row, UDim2.new(1,-58,0,7), UDim2.new(0,18,0.5,-3.5), C.TrackBg, 0)
                corner(bg, 4); stroke(bg, 0.85, C.RimOuter, 1)
                bg.ZIndex = 151

                local fl = frame(bg, UDim2.new(initV,0,1,0), nil, accentCol, 0)
                corner(fl, 4); fl.ZIndex = 152

                local th = frame(bg, UDim2.new(0,12,0,12), UDim2.new(initV,-6,0.5,-6), C.TxtPri, 0)
                corner(th, 6); stroke(th, 0.4, accentCol, 1.5)
                th.ZIndex = 153

                local numF = frame(row, UDim2.new(0,34,0,20), UDim2.new(1,-34,0.5,-10), C.AccentDark, 0.3)
                corner(numF, 5); numF.ZIndex = 151
                local numL = label(numF, tostring(math.floor(initV*255)), 10, C.TxtAccent, Enum.Font.GothamBold)
                numL.Size = UDim2.new(1,0,1,0); numL.TextXAlignment = Enum.TextXAlignment.Center
                numL.ZIndex = 152

                local curV  = initV
                local drag2 = false

                bg.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag2 = true end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if drag2 and i.UserInputType == Enum.UserInputType.MouseMovement then
                        local r = clamp((i.Position.X - bg.AbsolutePosition.X)/bg.AbsoluteSize.X, 0, 1)
                        curV = r
                        tw(fl, TI.snap, { Size = UDim2.new(r,0,1,0) })
                        tw(th, TI.snap, { Position = UDim2.new(r,-6,0.5,-6) })
                        numL.Text = tostring(math.floor(r*255))
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then drag2 = false end
                end)

                channels[lname] = { getV = function() return curV end }
                return row
            end

            chanRow("H", h, C.Accent,      0)
            chanRow("S", s, C.AccentLight, 32)
            chanRow("V", v, C.TxtSec,      64)

            -- Live color update
            RunService.RenderStepped:Connect(function()
                if not open then return end
                local nh = channels["H"].getV()
                local ns = channels["S"].getV()
                local nv = channels["V"].getV()
                col = Color3.fromHSV(nh, ns, nv)
                preview.BackgroundColor3 = col
                if cb then task.spawn(pcall, cb, col) end
            end)

            local hitBtn = Instance.new("TextButton")
            hitBtn.Size                  = UDim2.new(1,0,1,0)
            hitBtn.BackgroundTransparency= 1
            hitBtn.Text = ""; hitBtn.Parent = c
            hitBtn.MouseButton1Click:Connect(function()
                open = not open
                tw(sub, TI.med, { Size = open and UDim2.new(1,0,0,SUB_H) or UDim2.new(1,0,0,0) })
            end)
            if tip then addTip(preview, tip) end
        end

        -- в”Ђв”Ђ AddBind в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        function Tab:AddBind(name, default, cb, tip)
            local key       = default or Enum.KeyCode.Unknown
            local listening = false

            local c = card(44)
            local nameLbl = label(c, name, 13, C.TxtPri, Enum.Font.GothamMedium)
            nameLbl.Size = UDim2.new(1,-106,1,0)

            local keyWrap = frame(c, UDim2.new(0,94,0,26), UDim2.new(1,-98,0.5,-13), C.InputBg, T.Input)
            corner(keyWrap, 7)
            local kStroke = stroke(keyWrap, 0.80, C.RimOuter, 1)

            local keyLbl = label(keyWrap, key.Name, 11, C.TxtAccent, Enum.Font.GothamBold)
            keyLbl.Size             = UDim2.new(1,0,1,0)
            keyLbl.TextXAlignment   = Enum.TextXAlignment.Center

            local hitBtn = Instance.new("TextButton")
            hitBtn.Size = UDim2.new(1,0,1,0); hitBtn.BackgroundTransparency = 1
            hitBtn.Text = ""; hitBtn.ZIndex = 5; hitBtn.Parent = keyWrap

            hitBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyLbl.Text      = "..."
                keyLbl.TextColor3= C.TxtDim
                tw(kStroke, TI.fast, { Transparency = 0.3, Color = C.Warning })
                tw(keyWrap, TI.fast, { BackgroundTransparency = 0.0 })
            end)

            UserInputService.InputBegan:Connect(function(i, gp)
                if listening and not gp and i.UserInputType == Enum.UserInputType.Keyboard then
                    key       = i.KeyCode
                    listening = false
                    keyLbl.Text      = key.Name
                    tw(keyLbl,  TI.fast, { TextColor3 = C.TxtAccent })
                    tw(kStroke, TI.fast, { Transparency = 0.80, Color = C.RimOuter })
                    tw(keyWrap, TI.fast, { BackgroundTransparency = T.Input })
                elseif not listening and i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode == key then
                    if cb then task.spawn(pcall, cb, key) end
                end
            end)

            if tip then addTip(keyWrap, tip) end
            return {
                Get = function() return key end,
                Set = function(_, k) key = k; keyLbl.Text = k.Name end,
            }
        end

        -- в”Ђв”Ђ AddTextbox в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        function Tab:AddTextbox(name, placeholder, cb, tip)
            local c = card(58)

            local nameLbl = label(c, name, 12, C.TxtSec, Enum.Font.GothamMedium)
            nameLbl.Size     = UDim2.new(1,0,0,16)
            nameLbl.Position = UDim2.new(0,0,0,2)

            local inputWrap = frame(c, UDim2.new(1,0,0,28), UDim2.new(0,0,0,22), C.InputBg, T.Input)
            corner(inputWrap, 7)
            local iStroke = stroke(inputWrap, 0.84, C.RimOuter, 1)

            -- Left accent tick (hidden by default)
            local tick = frame(inputWrap, UDim2.new(0,2,0.65,0), UDim2.new(0,0,0.175,0), C.Accent, 1)
            corner(tick, 1)

            local tb = Instance.new("TextBox")
            tb.Size               = UDim2.new(1,-20,1,0)
            tb.Position           = UDim2.new(0,10,0,0)
            tb.BackgroundTransparency = 1
            tb.Text               = ""
            tb.PlaceholderText    = placeholder or "Type here..."
            tb.PlaceholderColor3  = C.TxtDim
            tb.TextColor3         = C.TxtPri
            tb.TextSize           = 12
            tb.Font               = Enum.Font.Gotham
            tb.TextXAlignment     = Enum.TextXAlignment.Left
            tb.BorderSizePixel    = 0
            tb.ClearTextOnFocus   = false
            tb.Parent             = inputWrap

            tb.Focused:Connect(function()
                tw(iStroke, TI.fast, { Transparency = 0.30, Color = C.Accent })
                tw(inputWrap, TI.fast, { BackgroundTransparency = 0.0 })
                tw(tick, TI.fast, { BackgroundTransparency = 0 })
            end)
            tb.FocusLost:Connect(function(enter)
                tw(iStroke, TI.fast, { Transparency = 0.84, Color = C.RimOuter })
                tw(inputWrap, TI.fast, { BackgroundTransparency = T.Input })
                tw(tick, TI.fast, { BackgroundTransparency = 1 })
                if enter and cb then task.spawn(pcall, cb, tb.Text) end
            end)
            tb:GetPropertyChangedSignal("Text"):Connect(function()
                if cb then task.spawn(pcall, cb, tb.Text) end
            end)

            if tip then addTip(inputWrap, tip) end
            return {
                Get = function() return tb.Text end,
                Set = function(_, v) tb.Text = v end,
            }
        end

        return Tab
    end -- Win:AddTab

    return Win
end -- DainGlass.Init

