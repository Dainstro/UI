--  TOOLTIP
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
local TipFrame, TipLabel, TipConn
local SGui -- set during Init

local function initTip()
    TipFrame = frame(SGui, UDim2.new(0, 200, 0, 30), UDim2.new(0,0,0,0), C.PanelAlt, 0.08)
    TipFrame.Name     = "DG_Tooltip"
    TipFrame.ZIndex   = 9998
    TipFrame.Visible  = false
    TipFrame.ClipsDescendants = false
    corner(TipFrame, 7)
    stroke(TipFrame, 0.78, C.RimInner, 1)
    pad(TipFrame, 0, 0, 10, 10)

    -- Subtle top accent line
    local accent = frame(TipFrame, UDim2.new(0.4, 0, 0, 1), UDim2.new(0.3, 0, 0, 0), C.Accent, 0)
    accent.ZIndex = 9999
    corner(accent, 1)

    TipLabel = label(TipFrame, "", 11, C.TxtSec, Enum.Font.Gotham)
    TipLabel.Size    = UDim2.new(1, 0, 1, 0)
    TipLabel.ZIndex  = 9999
    TipLabel.TextXAlignment = Enum.TextXAlignment.Center
end

local function showTip(txt)
    if not TipFrame then return end
    TipLabel.Text = txt
    TipFrame.Visible = true
    TipFrame.BackgroundTransparency = 1
    TipLabel.TextTransparency = 1
    tw(TipFrame, TI.fast, { BackgroundTransparency = 0.08 })
    tw(TipLabel, TI.fast, { TextTransparency = 0 })
    if TipConn then TipConn:Disconnect() end
    TipConn = RunService.RenderStepped:Connect(function()
        if not TipFrame or not TipFrame.Visible then return end
        local mp = UserInputService:GetMouseLocation()
        TipFrame.Position = UDim2.new(0, mp.X + 16, 0, mp.Y - 44)
        local objs = SGui:GetGuiObjectsAtPosition(mp.X, mp.Y)
        local topZ = 100
        for _, o in ipairs(objs) do
            if o ~= TipFrame and o.ZIndex and o.ZIndex > topZ then topZ = o.ZIndex end
        end
        TipFrame.ZIndex  = topZ + 1
        TipLabel.ZIndex  = topZ + 2
    end)
end

local function hideTip()
    if not TipFrame then return end
    tw(TipFrame, TI.snap, { BackgroundTransparency = 1 })
    local t = tw(TipLabel, TI.snap, { TextTransparency = 1 })
    t.Completed:Connect(function()
        if TipFrame then TipFrame.Visible = false end
        if TipConn  then TipConn:Disconnect(); TipConn = nil end
    end)
end

local function addTip(el, txt)
    if not txt or txt == "" then return end
    el.MouseEnter:Connect(function() showTip(txt) end)
    el.MouseLeave:Connect(function() hideTip() end)
end

