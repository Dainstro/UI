local NotifHolder

local function initNotifs()
    NotifHolder = frame(SGui, UDim2.new(0, 300, 1, -16), UDim2.new(1, -310, 0, 8), C.Win, 1)
    NotifHolder.Name    = "DG_Notifs"
    NotifHolder.ZIndex  = 7000
    local ly = Instance.new("UIListLayout")
    ly.FillDirection      = Enum.FillDirection.Vertical
    ly.VerticalAlignment  = Enum.VerticalAlignment.Bottom
    ly.HorizontalAlignment= Enum.HorizontalAlignment.Right
    ly.Padding            = UDim.new(0, 8)
    ly.SortOrder          = Enum.SortOrder.LayoutOrder
    ly.Parent = NotifHolder
    pad(NotifHolder, 0, 0, 0, 0)
end

function DainGlass.Notify(title, body, duration)
    if not NotifHolder then return end
    duration = duration or 4

    local card = frame(NotifHolder, UDim2.new(1, 0, 0, 76), UDim2.new(0,0,0,0), C.Panel, T.Panel)
    card.ZIndex = 7001
    card.ClipsDescendants = true
    -- Start off-screen right
    card.Position = UDim2.new(1.4, 0, 0, 0)
    corner(card, 12)
    stroke(card, T.RimOuter, C.RimOuter, 1)

    -- Left accent strip
    local strip = frame(card, UDim2.new(0, 2, 0.65, 0), UDim2.new(0, 0, 0.175, 0), C.Accent, 0)
    strip.ZIndex = 7002
    corner(strip, 1)

    -- Icon area
    local iconBg = frame(card, UDim2.new(0, 32, 0, 32), UDim2.new(0, 14, 0.5, -16), C.AccentDark, 0.3)
    iconBg.ZIndex = 7002
    corner(iconBg, 8)
    local iconLbl = label(iconBg, "в—€", 15, C.AccentLight, Enum.Font.GothamBold)
    iconLbl.Size = UDim2.new(1,0,1,0)
    iconLbl.ZIndex = 7003
    iconLbl.TextXAlignment = Enum.TextXAlignment.Center

    -- Text
    local titleL = label(card, title, 13, C.TxtPri, Enum.Font.GothamBold)
    titleL.Size     = UDim2.new(1,-62,0,18)
    titleL.Position = UDim2.new(0,54,0,14)
    titleL.ZIndex   = 7002

    local bodyL = label(card, body, 11, C.TxtSec, Enum.Font.Gotham)
    bodyL.Size          = UDim2.new(1,-62,0,16)
    bodyL.Position      = UDim2.new(0,54,0,34)
    bodyL.ZIndex        = 7002
    bodyL.TextTruncate  = Enum.TextTruncate.AtEnd

    -- Progress strip (bottom)
    local prog = frame(card, UDim2.new(1,0,0,2), UDim2.new(0,0,1,-2), C.Accent, 0)
    prog.ZIndex = 7002
    corner(prog, 1)

    -- Slide in
    tw(card, TI.spring, { Position = UDim2.new(0,0,0,0) })
    tw(prog, TI.linear(duration), { Size = UDim2.new(0,0,0,2) })

    task.delay(duration, function()
        tw(card, TI.fast, { Position = UDim2.new(1.3,0,0,0), BackgroundTransparency = 1 })
        task.wait(0.25)
        card:Destroy()
    end)
end

-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
--  INIT  вЂ” main window
-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
function DainGlass.Init(title, subtitle)

    -- ScreenGui
    SGui = Instance.new("ScreenGui")
    SGui.Name          = "DainGlassUI"
    SGui.ResetOnSpawn  = false
    SGui.ZIndexBehavior= Enum.ZIndexBehavior.Sibling
    SGui.DisplayOrder  = 999
    SGui.Parent        = PGui

    initTip()
    initNotifs()
    EnableBlur()

    -- в”Ђв”Ђ Window root в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    -- CanvasGroup: gives GroupTransparency and lets children share the glass look
    local win = Instance.new("CanvasGroup")
    win.Name                  = "DG_Window"
    win.Size                  = UDim2.new(0, 740, 0, 500)
    win.Position              = UDim2.new(0.5,-370, 0.5,-250)
    win.BackgroundColor3      = C.Win
    win.BackgroundTransparency= T.Win
    win.GroupTransparency     = 0
    win.BorderSizePixel       = 0
    win.Parent                = SGui
    corner(win, 14)

    -- Outer rim
    stroke(win, 0.80, C.RimOuter, 1)

    -- Subtle noise/grain overlay for depth
    local grainImg = Instance.new("ImageLabel")
    grainImg.Size                   = UDim2.new(1,0,1,0)
    grainImg.BackgroundTransparency = 1
    grainImg.Image                  = "rbxassetid://6318949272" -- noise texture
    grainImg.ImageTransparency      = 0.97
    grainImg.ScaleType              = Enum.ScaleType.Tile
    grainImg.TileSize               = UDim2.new(0,128,0,128)
    grainImg.ZIndex                 = 0
    grainImg.Parent                 = win

    -- Top-edge highlight line (glass rim illusion)
    local topRim = frame(win, UDim2.new(0.9,0,0,1), UDim2.new(0.05,0,0,0), C.RimOuter, 0.60)
    topRim.ZIndex = 1
    corner(topRim, 1)

    -- в”Ђв”Ђ Header в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    local hdr = frame(win, UDim2.new(1,0,0,56), UDim2.new(0,0,0,0), C.Header, T.Header)
    hdr.ZIndex = 3

    -- Header bottom separator
    local hdrLine = frame(win, UDim2.new(1,0,0,1), UDim2.new(0,0,0,56), C.RimInner, 0.80)
    hdrLine.ZIndex = 3

    -- Logo / accent mark
    local logoMark = frame(hdr, UDim2.new(0,4,0,26), UDim2.new(0,16,0.5,-13), C.Accent, 0)
    logoMark.ZIndex = 4
    corner(logoMark, 2)

    -- Title
    local titleL = label(hdr, title or "DainGlass", 17, C.TxtPri, Enum.Font.GothamBold)
    titleL.Size     = UDim2.new(0, 280, 0, 22)
    titleL.Position = UDim2.new(0, 28, 0, 10)
    titleL.ZIndex   = 4

    local subL = label(hdr, subtitle or "UI Library", 11, C.TxtDim, Enum.Font.Gotham)
    subL.Size     = UDim2.new(0, 280, 0, 14)
    subL.Position = UDim2.new(0, 28, 0, 32)
    subL.ZIndex   = 4

    -- Window controls (close, minimize)
    local function makeCtrl(xOffset, col, glyph)
        local btn = Instance.new("TextButton")
        btn.Size                  = UDim2.new(0, 22, 0, 22)
        btn.Position              = UDim2.new(1, xOffset, 0.5, -11)
        btn.BackgroundColor3      = col
        btn.BackgroundTransparency= 0.25
        btn.Text                  = glyph
        btn.TextColor3            = C.TxtPri
        btn.TextSize              = 10
        btn.Font                  = Enum.Font.GothamBold
        btn.BorderSizePixel       = 0
        btn.ZIndex                = 10
        btn.Parent                = hdr
        corner(btn, 6)
        btn.MouseEnter:Connect(function() tw(btn, TI.snap, { BackgroundTransparency = 0 }) end)
        btn.MouseLeave:Connect(function() tw(btn, TI.snap, { BackgroundTransparency = 0.25 }) end)
        return btn
    end

    local closeBtn = makeCtrl(-30, C.Danger,  "вњ•")
    local minBtn   = makeCtrl(-58, C.AccentDark, "в”Ђ")

    -- Drag
    do
        local dragging, ds, dp = false, nil, nil
        hdr.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging, ds, dp = true, i.Position, win.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                local d = i.Position - ds
                win.Position = UDim2.new(dp.X.Scale, dp.X.Offset+d.X, dp.Y.Scale, dp.Y.Offset+d.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
    end

    -- Minimize / Close behaviour
    local minimized = false
    local fullSz = UDim2.new(0, 740, 0, 500)
    local miniSz = UDim2.new(0, 740, 0, 56)

    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        tw(win, TI.med, { Size = minimized and miniSz or fullSz })
    end)

    closeBtn.MouseButton1Click:Connect(function()
        tw(win, TI.med, { GroupTransparency = 1, Size = UDim2.new(0,700,0,460) })
        DisableBlur()
        task.wait(0.35)
        SGui:Destroy()
    end)

    -- в”Ђв”Ђ Sidebar в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    local sidebar = frame(win, UDim2.new(0, 168, 1, -57), UDim2.new(0,0,0,57), C.Sidebar, T.Sidebar)
    sidebar.ZIndex = 2

    local sidebarLine = frame(win, UDim2.new(0,1,1,-57), UDim2.new(0,168,0,57), C.RimInner, 0.85)
    sidebarLine.ZIndex = 2

    -- Top tab list
    local topList = frame(sidebar, UDim2.new(1,0,1,-50), UDim2.new(0,0,0,0), C.Sidebar, 1)
    topList.ZIndex = 3
    local topLy = Instance.new("UIListLayout")
    topLy.FillDirection = Enum.FillDirection.Vertical
    topLy.Padding       = UDim.new(0, 3)
    topLy.SortOrder     = Enum.SortOrder.LayoutOrder
    topLy.Parent        = topList
    pad(topList, 10, 4, 6, 6)

    -- Bottom group sep
    local botSepLine = frame(sidebar, UDim2.new(0.75,0,0,1), UDim2.new(0.125,0,1,-52), C.RimInner, 0.84)
    botSepLine.ZIndex = 3

    -- Bottom tab list
    local botList = frame(sidebar, UDim2.new(1,0,0,46), UDim2.new(0,0,1,-50), C.Sidebar, 1)
    botList.ZIndex = 3
    local botLy = Instance.new("UIListLayout")
    botLy.FillDirection = Enum.FillDirection.Vertical
    botLy.Padding       = UDim.new(0, 3)
    botLy.SortOrder     = Enum.SortOrder.LayoutOrder
    botLy.Parent        = botList
    pad(botList, 4, 4, 6, 6)

    -- Active pill indicator
    local pill = frame(sidebar, UDim2.new(0, 3, 0, 20), UDim2.new(0, 2, 0, 0), C.Accent, 1)
    pill.ZIndex = 6
    corner(pill, 2)

    -- в”Ђв”Ђ Content Area в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    local content = frame(win, UDim2.new(1,-172,1,-65), UDim2.new(0,170,0,57), C.Win, 1)
    content.ZIndex = 2
    content.ClipsDescendants = true

    -- Search bar
    local searchWrap = frame(content, UDim2.new(1,-20,0,32), UDim2.new(0,10,0,10), C.InputBg, T.Input)
    searchWrap.ZIndex = 3
    corner(searchWrap, 8)
    local searchStroke = stroke(searchWrap, 0.87, C.RimOuter, 1)
    pad(searchWrap, 0, 0, 8, 8)

    local searchIcon = label(searchWrap, "вЊ•", 15, C.TxtDim)
    searchIcon.Size    = UDim2.new(0, 22, 1, 0)
    searchIcon.TextXAlignment = Enum.TextXAlignment.Center
    searchIcon.ZIndex = 4

    local searchBox = Instance.new("TextBox")
    searchBox.Size               = UDim2.new(1,-30,1,0)
    searchBox.Position           = UDim2.new(0,26,0,0)
    searchBox.BackgroundTransparency = 1
    searchBox.Text               = ""
    searchBox.PlaceholderText    = "Filter components..."
    searchBox.PlaceholderColor3  = C.TxtDim
    searchBox.TextColor3         = C.TxtPri
    searchBox.TextSize           = 12
    searchBox.Font               = Enum.Font.Gotham
    searchBox.BorderSizePixel    = 0
    searchBox.ClearTextOnFocus   = false
    searchBox.ZIndex             = 4
    searchBox.Parent             = searchWrap

    searchBox.Focused:Connect(function()
        tw(searchStroke, TI.fast, { Transparency = 0.35, Color = C.Accent })
        tw(searchIcon, TI.fast, { TextColor3 = C.Accent })
    end)
    searchBox.FocusLost:Connect(function()
        tw(searchStroke, TI.fast, { Transparency = 0.87, Color = C.RimOuter })
        tw(searchIcon, TI.fast, { TextColor3 = C.TxtDim })
    end)

    -- Scrollable tab content host
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name                = "DG_Scroll"
    scroll.Size                = UDim2.new(1,-20,1,-54)
    scroll.Position            = UDim2.new(0,10,0,48)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel     = 0
    scroll.ScrollBarThickness  = 2
    scroll.ScrollBarImageColor3= C.AccentGlow
    scroll.CanvasSize          = UDim2.new(0,0,0,0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.ScrollingDirection  = Enum.ScrollingDirection.Y
    scroll.ElasticBehavior     = Enum.ElasticBehavior.Always
    scroll.ZIndex              = 3
    scroll.Parent              = content

    local scrollLy = Instance.new("UIListLayout")
    scrollLy.FillDirection = Enum.FillDirection.Vertical
    scrollLy.Padding       = UDim.new(0, 5)
    scrollLy.SortOrder     = Enum.SortOrder.LayoutOrder
    scrollLy.Parent        = scroll
    pad(scroll, 2, 10, 0, 0)

    -- в”Ђв”Ђ Tab system в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    local tabs      = {}
    local activeTab = nil
    local activBtn  = nil

    local function switchTab(tabData, btn)
        if activeTab then
            activeTab.container.Visible = false
            if activBtn then
                tw(activBtn, TI.fast, { BackgroundTransparency = 1, TextColor3 = C.TxtDim })
            end
        end
        activeTab = tabData
        activBtn  = btn
        tabData.container.Visible = true
        tw(btn, TI.fast, { BackgroundTransparency = 0.75, TextColor3 = C.TxtPri })

        -- Animate pill to new position
        local btnAbs  = btn.AbsolutePosition
        local sideAbs = sidebar.AbsolutePosition
        local relY    = btnAbs.Y - sideAbs.Y + btn.AbsoluteSize.Y * 0.5 - 10
        tw(pill, TI.med, { Position = UDim2.new(0, 2, 0, relY), BackgroundTransparency = 0 })
    end

    -- Search filter
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        if not activeTab then return end
        local q = searchBox.Text:lower()
        for _, child in ipairs(activeTab.container:GetChildren()) do
            if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
                local nl = child:FindFirstChildWhichIsA("TextLabel")
                if nl then
                    child.Visible = (q == "" or nl.Text:lower():find(q, 1, true) ~= nil)
                end
            end
        end
    end)

    -- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    --  WINDOW OBJECT
    -- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
    local Win = {}

    function Win:AddTab(name, icon, pinBottom)
        -- Tab container (hidden until active)
        local container = frame(scroll, UDim2.new(1,0,0,0), UDim2.new(0,0,0,0), C.Win, 1)
        container.Name             = "DGTab_"..name
        container.AutomaticSize    = Enum.AutomaticSize.Y
        container.Visible          = false
        container.ZIndex           = 3

        local cLy = Instance.new("UIListLayout")
        cLy.FillDirection = Enum.FillDirection.Vertical
        cLy.Padding       = UDim.new(0, 5)
        cLy.SortOrder     = Enum.SortOrder.LayoutOrder
        cLy.Parent        = container

        -- Sidebar button
        local tabBtn = Instance.new("TextButton")
        tabBtn.Size                  = UDim2.new(1,0,0,34)
        tabBtn.BackgroundColor3      = C.AccentDark
        tabBtn.BackgroundTransparency= 1
        tabBtn.Text                  = (icon and icon.." " or "") .. name
        tabBtn.TextColor3            = C.TxtDim
        tabBtn.TextSize              = 12
        tabBtn.Font                  = Enum.Font.GothamMedium
        tabBtn.TextXAlignment        = Enum.TextXAlignment.Left
        tabBtn.BorderSizePixel       = 0
        tabBtn.ZIndex                = 4
        tabBtn.Parent                = pinBottom and botList or topList
        corner(tabBtn, 8)
        pad(tabBtn, 0, 0, 12, 4)

        local tabData = { name = name, container = container, btn = tabBtn, order = 0 }
        table.insert(tabs, tabData)

        tabBtn.MouseButton1Click:Connect(function() switchTab(tabData, tabBtn) end)
        tabBtn.MouseEnter:Connect(function()
            if activBtn ~= tabBtn then tw(tabBtn, TI.snap, { TextColor3 = C.TxtSec }) end
        end)
        tabBtn.MouseLeave:Connect(function()
            if activBtn ~= tabBtn then tw(tabBtn, TI.snap, { TextColor3 = C.TxtDim }) end
        end)

        if #tabs == 1 then switchTab(tabData, tabBtn) end

        -- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
        --  TAB OBJECT
        -- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
        local Tab = {}

        local function nextOrder()
            tabData.order += 1; return tabData.order
        end

        -- в”Ђв”Ђ Card wrapper в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        local function card(h)
            local c = frame(container, UDim2.new(1,0,0,h or 44), nil, C.Panel, T.Panel)
            c.BorderSizePixel = 0
            c.LayoutOrder     = nextOrder()
            corner(c, 10)
            stroke(c, T.RimOuter, C.RimOuter, 1)
            pad(c, 0, 0, 14, 14)
            -- Hover glow stroke
            c.MouseEnter:Connect(function()
                tw(c:FindFirstChildWhichIsA("UIStroke"), TI.fast, { Transparency = 0.60, Color = C.RimInner })
            end)
            c.MouseLeave:Connect(function()
                tw(c:FindFirstChildWhichIsA("UIStroke"), TI.fast, { Transparency = T.RimOuter, Color = C.RimOuter })
            end)
            return c
        end

        -- в”Ђв”Ђ AddSection в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
        function Tab:AddSection(name)
            local wrap = frame(container, UDim2.new(1,0,0,24), nil, C.Win, 1)
            wrap.LayoutOrder = nextOrder()

            local line = frame(wrap, UDim2.new(1,0,0,1), UDim2.new(0,0,0.5,0), C.RimOuter, 0.87)
