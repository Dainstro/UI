    sidebar.ZIndex = 2

    local sidebarRight = MakeFrame(sidebar, UDim2.new(0, 1, 1, 0), UDim2.new(1, -1, 0, 0), COLORS.Border, 0.88)

    -- Top tab group
    local topGroup = MakeFrame(sidebar, UDim2.new(1, 0, 1, -44), UDim2.new(0, 0, 0, 0), COLORS.Background, 1)
