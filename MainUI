    topLayout.FillDirection = Enum.FillDirection.Vertical
    topLayout.Padding = UDim.new(0, 2)
    topLayout.Parent = topGroup
    MakePadding(topGroup, 8, 4, 0, 0)

    -- Bottom group separator
    local bottomSep = MakeFrame(sidebar, UDim2.new(0.8, 0, 0, 1), UDim2.new(0.1, 0, 1, -45), COLORS.Border, 0.82)

    -- Bottom tab group
    local bottomGroup = MakeFrame(sidebar, UDim2.new(1, 0, 0, 40), UDim2.new(0, 0, 1, -44), COLORS.Background, 1)
    local bottomLayout = Instance.new("UIListLayout")
